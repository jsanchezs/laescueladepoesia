---
import BaseLayout from "../../layouts/BaseLayout.astro";

const bookingUrl = `${import.meta.env.BASE_URL}cursos/intermedio-martes/#reserva`;
---

<BaseLayout
  title="Pago cancelado | La Escuela de Poesía"
  description="El pago de la reserva no se ha completado."
>
  <main class="payment-result">
    <div class="payment-result__card">
      <p class="section-kicker">Pago cancelado</p>
      <h1>No se ha hecho<br /><em>ningún cargo.</em></h1>
      <p>Puedes volver al curso e intentarlo de nuevo cuando quieras.</p>
      <a class="button" href={bookingUrl}>Volver a la reserva</a>
    </div>
  </main>
</BaseLayout>

<style>
  .payment-result { display: grid; min-height: 100vh; padding: 2rem; place-items: center; }
  .payment-result__card { width: min(680px, 100%); padding: clamp(2rem, 7vw, 5rem); border: 1px solid var(--ink); background: var(--paper-light); }
  h1 { margin: 0 0 2rem; font-family: var(--serif); font-size: clamp(3.5rem, 9vw, 6.5rem); font-weight: 400; letter-spacing: -.04em; line-height: .88; }
  h1 em { color: var(--red); font-weight: 400; }
  p:not(.section-kicker) { max-width: 520px; color: var(--muted); }
  .button { margin-top: 1.5rem; }
</style>
